---
import { Font } from "astro:assets";
import "../styles/global.css";
---
<!doctype html>
<html lang="en" class="scrollbar-thin scroll-smooth scrollbar-thumb-neutral-300 scrollbar-track-neutral-50 hover:scrollbar-thumb-neutral-200 scrollbar-gutter-both">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<Font cssVariable="--font-ibm-plex-sans" />
		<Font cssVariable="--font-ibm-plex-serif" />
		<Font cssVariable="--font-kalam" />
	</head>
	<body >
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
